<IfModule mod_negotiation.c>
    Options -MultiViews -Indexes
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteRule ^index\.html$ - [L]
    RewriteRule ^portfolio/?$ /proyectos [R=301,L]
    RewriteRule ^portfolio/(.+)$ /proyectos/$1 [R=301,L]
    RewriteRule ^portfolio-single/?$ /proyectos [R=301,L]
    RewriteRule ^service-details/?$ /servicios/ingenieria-estructural [R=301,L]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.html [L]
</IfModule>
